# === 方式A: Google Apps Script（おすすめ / Vercelで鍵不要）===
# Google Apps Script を「ウェブアプリ」としてデプロイしたURL
VITE_GAS_WEBAPP_URL=

# （推奨）GAS 側で TOKEN を設定した場合は同じ値をここにも設定
VITE_GAS_TOKEN=

# === 方式B: サービスアカウント（ローカル/サーバー実行向け）===
# ※ VITE_GAS_WEBAPP_URL が未設定のときのみ、/api 経由（Vercel Functions / ローカル Express）を使います
# SPREADSHEET_ID=
# SHEET_NAME=シート1
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# API_PORT=8788
