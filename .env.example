# === Google スプレッドシート（サービスアカウント・ログイン不要）===
# スプレッドシートのURL …/spreadsheets/d/【この部分がID】/edit
SPREADSHEET_ID=

# 保存先のタブ名（デフォルトは シート1）
SHEET_NAME=シート1

# サービスアカウント JSON キーのパス（プロジェクト直下のファイルでも可。鍵ファイルは .gitignore に入れてプッシュしない）
GOOGLE_APPLICATION_CREDENTIALS=./samuraiseo-490701-735437491637.json

# または JSON 全文を1行で（改行なし）
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# API サーバーのポート（開発時。Vite の proxy と一致させる）
API_PORT=8788

# 本番で npm run start するときの待受ポート
# PORT=3000
